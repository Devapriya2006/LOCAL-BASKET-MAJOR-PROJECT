# ── Environment / secrets ─────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Dependencies ───────────────────────────────────────────────────────
node_modules/
backend/node_modules/

# ── Logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Uploaded / user content (don't commit runtime uploads) ─────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── OS / editor junk ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Build artifacts ──────────────────────────────────────────────────────
dist/
build/
*.tmp
