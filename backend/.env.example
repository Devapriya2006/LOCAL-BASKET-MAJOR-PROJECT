# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/localbasket
# Atlas (uncomment and replace with your connection string):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/localbasket

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=localbasket_super_secret_key_change_this_in_production
JWT_EXPIRE=7d

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Go to Google Account → Security → App Passwords → Select "Mail" → Generate
# Step 3: Use the 16-char app password below (NOT your regular Gmail password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM="LocalBasket 🧺 <your_gmail@gmail.com>"

# ─── Twilio SMS OTP ───────────────────────────────────────────────────────────
# Step 1: Sign up free at https://www.twilio.com
# Step 2: Go to Console Dashboard → copy Account SID and Auth Token
# Step 3: Buy/get a free trial phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ─── OTP Settings ─────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10

# ─── Client URL (for CORS) ────────────────────────────────────────────────────
CLIENT_URL=http://127.0.0.1:5500
